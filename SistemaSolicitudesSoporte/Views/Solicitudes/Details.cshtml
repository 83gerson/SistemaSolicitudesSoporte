@model SistemaSolicitudesSoporte.Models.Solicitud
@{
    ViewBag.Title = "Detalle de Solicitud";
}

<h2>Detalle de la Solicitud #@Model.Id</h2>

<dl class="dl-horizontal">
    <dt>Nombre del solicitante</dt>
    <dd>@Model.NombreSolicitante</dd>

    <dt>Correo electrónico</dt>
    <dd>@Model.Email</dd>

    <dt>Categoría</dt>
    <dd>@Model.Categoria</dd>

    <dt>Estado</dt>
    <dd>@Model.Estado</dd>

    <dt>Descripción</dt>
    <dd>@Model.Descripcion</dd>

    <dt>Fecha de registro</dt>
    <dd>@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>
</dl>

@Html.ActionLink("Volver a la lista", "Index", null, null, new { @class = "btn btn-default" })
